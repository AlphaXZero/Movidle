@page "/"
@rendermode InteractiveServer

<div class="page-hero">
    <h1>MOVIDLE</h1>
    <p class="subtitle">Guess the movie from its data</p>
</div>

<table id="movies-table">
    <thead>
        <tr>
            <th>Title</th>
            <th>Director</th>
            <th>Year</th>
            <th>Genre</th>
            <th>Metascore</th>
            <th>Country</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var m in movies)
        {
            <tr>
                <td data-label="Title" class="@base_verif(m.Title, rdm_movie.Title)">@m.Title</td>
                <td data-label="Director" class="@base_verif(m.Director, rdm_movie.Director)">@m.Director</td>
                <td data-label="Year" class="@year_verif(m.Year, rdm_movie.Year)">@m.Year</td>
                <td data-label="Genre" class="@genre_verif(m.Genres, rdm_movie.Genres)">@string.Join(", ", m.Genres)
                </td>
                <td data-label="Metascore" class="@year_verif(m.Metascore, rdm_movie.Metascore)">@m.Metascore</td>
                <td data-label="Country" class="@genre_verif(m.Countries, rdm_movie.Countries)">@string.Join(", ",
                                                                                                                                                                                                                                                                                                                            m.Countries)</td>
                    <td>
                        @if (isFavorite(m) == "favorite")
                        {
                            <button class="btn-secondary_unfav" @onclick="() => RemoveFromFavorites(m)">♥ Unfavorite</button>
                        }
                        else
                        {
                            <button class="btn-secondary" @onclick="() => AddToFavorites(m)">♡ Favorite</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div class="search-row">
        <input @bind-value="title" @bind-value:event="oninput" placeholder="Enter a movie title…"
               @onkeydown="HandleKeyDown" />
        <button @onclick="MakeAGuess">Guess</button>
    </div>

    <p class="game-log">@log</p>

    @if (won)
    {
        <div class="modal-overlay">
            <div class="modal-card">
                <h2 class="modal-title">🎬 You got it!</h2>
                <p class="modal-subtitle">The movie was</p>
                <p class="modal-movie">@rdm_movie.Title</p>
                <p class="modal-tries">Found in @movies.Count guess@(movies.Count > 1 ? "es" : "")</p>
                <button @onclick="Restart">Play again</button>
            </div>
        </div>
    }