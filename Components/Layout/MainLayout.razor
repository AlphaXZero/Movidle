@namespace Movidle.Components.Layout
@inherits LayoutComponentBase
@inject AppState AppState

<div class="page-container">
    <header class="site-navbar">
        <a href="/" class="navbar-brand">Movidle</a>

        <ul class="navbar-links">
            <li>
                <NavLink href="/" class="nav-link" Match="NavLinkMatch.All">Home</NavLink>
            </li>
            <li>
                <NavLink href="/favorites" class="nav-link">Favorites</NavLink>
            </li>
            <li>
                <NavLink href="/login" class="nav-link">Login</NavLink>
            </li>
        </ul>

        @if (AppState.Username != string.Empty)
        {
            <span class="navbar-user">Logged in as <span class="username">@AppState.Username</span></span>
        }
        else
        {
            <span class="navbar-user">Please log in</span>
        }
    </header>

    <main class="page-content">
        @Body
    </main>
</div>